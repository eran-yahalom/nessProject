<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="e commerce Test Suite"
       parallel="methods"
       thread-count="1"
       data-provider-thread-count="10">
    <listeners>
        <listener class-name="listeners.TestNGListener"/>
        <listener class-name="listeners.ProgressListener"/>
        <listener class-name="utils.RetryListener"/>
    </listeners>

    <test name="e commerce tests">
        <classes>
            <class name="launchers.GeneralLauncher"/>
        </classes>
    </test>
</suite>